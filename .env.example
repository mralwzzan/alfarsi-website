# متغيّرات البيئة — تُضاف في Vercel: Settings → Environment Variables
# (انسخها بنفس الأسماء وأعد النشر بعد إضافتها)

# مفتاح Moyasar العام (للواجهة) — من Moyasar: Settings → API Keys
VITE_MOYASAR_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# مفتاح Moyasar السرّي (للخادم فقط — لا يُعرض في الواجهة)
MOYASAR_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# رابط مشروع Supabase
SUPABASE_URL=https://gqiwtwcsijmkvcyhyqds.supabase.co

# مفتاح service_role من Supabase (Settings → API) — سرّي تماماً
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxx
